{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "层层加码",
  "version": "../package.json",
  "identifier": "com.laymask",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Laymask",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["png"],
        "name": "PNG Image",
        "description": "PNG Image File",
        "mimeType": "image/png",
        "role": "Viewer"
      },
      {
        "ext": ["jpg", "jpeg"],
        "name": "JPEG Image",
        "description": "JPEG Image File",
        "mimeType": "image/jpeg",
        "role": "Viewer"
      },
      {
        "ext": ["bmp"],
        "name": "BMP Image",
        "description": "Bitmap Image File",
        "mimeType": "image/bmp",
        "role": "Viewer"
      },
      {
        "ext": ["gif"],
        "name": "GIF Image",
        "description": "GIF Image File",
        "mimeType": "image/gif",
        "role": "Viewer"
      },
      {
        "ext": ["webp"],
        "name": "WebP Image",
        "description": "WebP Image File",
        "mimeType": "image/webp",
        "role": "Viewer"
      }
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsi"
      }
    }
  }
}
